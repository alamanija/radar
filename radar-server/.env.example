# Copy to .env and fill in.
DATABASE_URL=postgres://radar:radar@localhost:5433/radar
SERVER_PORT=8787
RUST_LOG=radar_server=debug,tower_http=info,sqlx=warn

# Clerk session JWTs are verified against these on every authed request.
# Find both values in your Clerk dashboard → API keys → "Show JWKS public key".
# CLERK_JWKS_URL is the JWKS endpoint (e.g. https://<your-app>.clerk.accounts.dev/.well-known/jwks.json).
# CLERK_ISSUER is the exact `iss` claim Clerk stamps on session tokens (e.g. https://<your-app>.clerk.accounts.dev).
CLERK_JWKS_URL=
CLERK_ISSUER=
