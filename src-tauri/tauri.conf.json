{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Radar",
  "version": "../package.json",
  "identifier": "com.radar.dev",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Radar",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/alamanija/radar/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2N0JFNUNDOEVDRUQwOTMKUldTVDBNNk96T1Y3eGs1ODJHVkxjdko0RCtDVmdFT1FGUnNCR1FoMENzaW51Nk5MRDVQVno3QysK",
      "dangerousInsecureTransportProtocol": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
